# .gitattributes — enforce LF line endings everywhere.
# Prevents Windows CRLF from breaking shell scripts inside Docker containers.
# Without this, bash scripts fail with "bad interpreter: No such file or directory".

# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Shell scripts — must be LF, never CRLF
*.sh   text eol=lf
*.bash text eol=lf

# PowerShell — CRLF is fine on Windows, LF still works
*.ps1  text eol=crlf

# Dockerfiles — LF required
Dockerfile*    text eol=lf
*.Dockerfile   text eol=lf
*.dockerignore text eol=lf

# Config files
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.env  text eol=lf
*.conf text eol=lf
*.toml text eol=lf

# Source code
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf
*.sql  text eol=lf

# Makefile — tabs must be preserved (not spaces)
Makefile text eol=lf

# Binary files — no line ending conversion
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.tar    binary
