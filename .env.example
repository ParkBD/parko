# ─── ParkNest Environment Variables ──────────────────────────────────────────
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git — add it to .gitignore.
# Secrets (passwords, keys) should use Docker secrets in production:
#   see scripts/init-secrets.sh

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
DOMAIN=parknest.com
CORS_ORIGIN=https://parknest.com,https://www.parknest.com
APP_URL=https://parknest.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=parknest
POSTGRES_DB=parknest_db
# POSTGRES_PASSWORD → Docker secret: secrets/db_password.txt (production)
POSTGRES_PASSWORD=dev_password_only

# DATABASE_URL is auto-built in docker-compose — set manually for local dev:
DATABASE_URL=postgresql://parknest:dev_password_only@localhost:5433/parknest_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD → Docker secret: secrets/redis_password.txt (production)
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# JWT_SECRET → Docker secret: secrets/jwt_secret.txt (production)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── MinIO (S3-compatible object storage) ──────────────────────────────────────
MINIO_ROOT_USER=parknest
# MINIO_ROOT_PASSWORD → Docker secret (production)
MINIO_ROOT_PASSWORD=change-this-in-production
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_SPACES=parking-spaces
MINIO_BUCKET_PROFILES=user-profiles

# ── SMTP (email) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@parknest.com
SMTP_PASS=your-app-password
SMTP_FROM=ParkNest <noreply@parknest.com>

# ── Payment ───────────────────────────────────────────────────────────────────
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# ── Next.js (web) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://parknest.com

# ── Docker image registry ─────────────────────────────────────────────────────
REGISTRY=ghcr.io
IMAGE_REPO=your-github-org/parknest
IMAGE_TAG=latest

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-this-strong-password
